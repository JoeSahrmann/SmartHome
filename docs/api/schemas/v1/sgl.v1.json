{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smarthome.local/schemas/v1/sgl.v1.json",
  "title": "SGL Sync Grocery List Contract v1",
  "type": "object",
  "required": ["request", "response"],
  "properties": {
    "request": {
      "type": "object",
      "required": ["body"],
      "properties": {
        "body": {
          "type": "object",
          "required": ["listId", "householdId", "baseVersion", "changes"],
          "properties": {
            "listId": { "$ref": "common.v1.json#/$defs/Id" },
            "householdId": { "$ref": "common.v1.json#/$defs/Id" },
            "baseVersion": { "type": "integer", "minimum": 0 },
            "changes": {
              "type": "array",
              "minItems": 1,
              "maxItems": 200,
              "items": {
                "type": "object",
                "required": ["op"],
                "properties": {
                  "op": {
                    "type": "string",
                    "enum": ["add", "update", "remove", "toggleChecked"]
                  },
                  "itemId": { "$ref": "common.v1.json#/$defs/Id" },
                  "payload": { "type": "object" }
                },
                "additionalProperties": false
              }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["listId", "newVersion", "appliedChanges", "conflicts", "updatedAt"],
      "properties": {
        "listId": { "$ref": "common.v1.json#/$defs/Id" },
        "newVersion": { "type": "integer", "minimum": 0 },
        "appliedChanges": { "type": "integer", "minimum": 0 },
        "conflicts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["op", "reason"],
            "properties": {
              "op": { "type": "string" },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "updatedAt": { "$ref": "common.v1.json#/$defs/Timestamp" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
