{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://smarthome.local/schemas/v1/bgl.v1.json",
  "title": "BGL Build Grocery List Contract v1",
  "type": "object",
  "required": ["request", "response"],
  "properties": {
    "request": {
      "type": "object",
      "required": ["body"],
      "properties": {
        "headers": {
          "type": "object",
          "properties": {
            "X-Timezone": { "$ref": "common.v1.json#/$defs/Timezone" }
          },
          "additionalProperties": true
        },
        "body": {
          "type": "object",
          "required": ["householdId", "weekStartDate"],
          "properties": {
            "householdId": { "$ref": "common.v1.json#/$defs/Id" },
            "weekStartDate": { "$ref": "common.v1.json#/$defs/Date" },
            "overwrite": { "type": "boolean", "default": false }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["listId", "householdId", "weekStartDate", "generatedAt", "items"],
      "properties": {
        "listId": { "$ref": "common.v1.json#/$defs/Id" },
        "householdId": { "$ref": "common.v1.json#/$defs/Id" },
        "weekStartDate": { "$ref": "common.v1.json#/$defs/Date" },
        "generatedAt": { "$ref": "common.v1.json#/$defs/Timestamp" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "quantity"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "quantity": { "type": "number", "minimum": 0 },
              "unit": { "type": "string" },
              "sourceRecipeId": { "$ref": "common.v1.json#/$defs/Id" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
